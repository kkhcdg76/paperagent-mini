# Default: local Ollama model. No API key needed.
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
OLLAMA_URL=http://localhost:11434/api/chat

# Development/demo mode:
# true  = skip live arXiv search and use known paper IDs below
# false = search arXiv directly
USE_FALLBACK_PAPERS=true
ARXIV_RETRY_WAIT_SECONDS=5
FALLBACK_ARXIV_IDS=2501.04227,2503.18102,2408.06292

# OpenAI option:
# If you use OpenAI, uncomment and fill this in locally.
# Do not commit a real personal API key.
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=your-openai-api-key-here

# LM Studio option:
# LLM_PROVIDER=lmstudio
# LLM_MODEL=local-model
# LM_STUDIO_BASE_URL=http://localhost:1234/v1
# LM_STUDIO_API_KEY=lm-studio
